{
  "id": "@adsorgcn/soulforge-plugin",
  "name": "@adsorgcn/soulforge-plugin",
  "displayName": "SoulForge 灵魂打印机",
  "description": "三步法蒸馏写作风格。plugin不调用LLM，只生成prompt和写文件。agent用自己的模型执行蒸馏。",
  "version": "4.0.0",
  "author": "ilang-ai",
  "homepage": "https://ilang.ai",
  "entryPoint": "dist/index.js",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": ["soulforge_distill_search", "soulforge_distill_corpus", "soulforge_write"]
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "samplingSize": {
        "type": "number",
        "default": 50000,
        "description": "采样字数上限"
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "permissions": {
    "filesystem": true,
    "env": false
  }
}
