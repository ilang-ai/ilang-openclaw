{
  "id": "@adsorgcn/soulforge-plugin",
  "name": "@adsorgcn/soulforge-plugin",
  "displayName": "SoulForge 灵魂打印机",
  "description": "输入人名或语料，蒸馏写作风格。展示预览后经用户确认才写入SOUL.md，自动备份旧版本（带时间戳）。语料通过用户配置的模型提供商进行分析。",
  "version": "2.5.0",
  "author": "ilang-ai",
  "homepage": "https://ilang.ai",
  "entryPoint": "dist/index.js",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": ["soulforge_distill_search", "soulforge_distill_corpus"]
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "samplingSize": {
        "type": "number",
        "default": 50000,
        "description": "采样字数上限"
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "permissions": {
    "filesystem": true,
    "env": false
  }
}
