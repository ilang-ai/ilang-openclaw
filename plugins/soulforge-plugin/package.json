{
  "name": "@adsorgcn/soulforge-plugin",
  "version": "4.0.5",
  "description": "Writing style analysis plugin. Uses three-step method (observe facts, deduce traits, verify with corpus) to extract expression DNA. Plugin generates prompts only; agent runs analysis with its own model. User reviews and confirms before any file write.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "soul",
    "persona",
    "distill",
    "writing-style",
    "ilang"
  ],
  "author": "iLang Inc. <contact@ilang.ai>",
  "license": "MIT",
  "homepage": "https://ilang.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilang-ai/ilang-openclaw.git",
    "directory": "plugins/soulforge-plugin"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2"
    },
    "metadata": {
      "emoji": "🔥",
      "category": "Automation"
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  }
}